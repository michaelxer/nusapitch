# Copy values into .credentials/llm.env or .credentials/email.env for local use.
# Do not store real secrets in this file.

NUSAPITCH_LLM_PROVIDER=OpenAI-compatible
NUSAPITCH_LLM_BASE_URL=https://api.example.com/v1
NUSAPITCH_LLM_SECRET=replace-with-your-llm-secret
NUSAPITCH_LLM_MODEL=example-chat-model

NUSAPITCH_EMAIL_ADDRESS=sender@example.com
NUSAPITCH_EMAIL_SECRET=replace-with-your-email-secret
NUSAPITCH_SMTP_HOST=smtp.example.com
NUSAPITCH_SMTP_PORT=465
NUSAPITCH_IMAP_HOST=imap.example.com
NUSAPITCH_IMAP_PORT=993
